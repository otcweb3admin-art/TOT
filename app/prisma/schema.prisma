  createdBy          UserProfile @relation("OperatingCapacityCreatedBy", fields: [createdByProfileId], references: [id])
  updatedByProfileId String
  updatedBy          UserProfile @relation("OperatingCapacityUpdatedBy", fields: [updatedByProfileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== P2-022 Merchant Stage Handoff Foundation (TASK-057, Phase C) =====
// MINIMAL human-recorded node-to-node handoff. Records a handoff ONLY — NO auto-approval,
// NO auto-transition, NO review flow, NO reject/needs_revision/lock states (those are
// Phase D), NO node-status mutation. A merchant has many handoffs. See
// role-based-ui-and-stage-handoff-architecture-v1.md.
enum MerchantStageNode {
  merchant
  profile
  baseline
  operating_capacity
  diagnosis
  account_setup
  material_collection
  content_operation
  live_planning
  lead_conversion
  data_review
  growth_plan
  workspace
}

enum MerchantStageHandoffStatus {
  submitted // 已提交，待接收
  received // 已被目标角色接收（不代表已审批/放行）
  cancelled // 已被提交人/管理员取消
}

model MerchantStageHandoff {
  id         String   @id @default(uuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  fromNode MerchantStageNode
  toNode   MerchantStageNode
  status   MerchantStageHandoffStatus @default(submitted)

  summary         String?
  gapSummary      String?
  riskSummary     String?
  evidenceSummary String?

  // Who submitted (required) / target role / who received (optional) / who reviewed (Phase D, optional).
  submittedByProfileId String
  submittedBy          UserProfile  @relation("HandoffSubmittedBy", fields: [submittedByProfileId], references: [id])
  receivedByRole       Role
  receivedByProfileId  String?
  receivedBy           UserProfile? @relation("HandoffReceivedBy", fields: [receivedByProfileId], references: [id])
  reviewedByProfileId  String?
  reviewedBy           UserProfile? @relation("HandoffReviewedBy", fields: [reviewedByProfileId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  receivedAt DateTime?
  reviewedAt DateTime?

  @@index([merchantId])
}
