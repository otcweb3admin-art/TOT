// TOT — Prisma schema (P0 foundation only)
//
// P0 scope: validate that the app can connect to the database and run migrations.
// This is NOT the business data model. Business models (Profile / Merchant / Node /
// Approval / Transition / RealMetric / AttributionRecord / Experience ...) are defined
// in later phases per docs/project/P0_FOUNDATION_PLAN.md and the architecture docs.
//
// Supabase connection (via Prisma):
//   DATABASE_URL = pooled connection (Transaction pooler, port 6543) — app runtime
//   DIRECT_URL   = direct connection (port 5432)                     — migrations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Minimal foundation model — used only to validate connectivity & migrations.
// Safe to drop/replace when real business models land. Not a business entity.
model HealthCheck {
  id        String   @id @default(uuid())
  note      String   @default("p0")
  createdAt DateTime @default(now())
}

// ===== P1 Auth + Role foundation =====
// Roles are authoritative per docs/architecture/ROLE_MODEL.md (6 roles).
// NOTE: SYSTEM_BLUEPRINT additionally mentions `outsource` (a 7th role) — this is a
// known doc discrepancy (see project-audit-v1 R2). NOT added here to avoid inventing
// roles; add later via a new migration if the team decides to adopt it.
enum Role {
  merchant
  collector
  operator
  executor
  admin
  ai_worker
}

enum UserStatus {
  active
  disabled
}

// Minimal identity/role profile, linked 1:1 to a Supabase auth user.
// JIT-provisioned on first login (see lib/auth/dal.ts). NOT a business entity.
// Default role `operator` is a P1 placeholder; proper role assignment + signup
// restriction are later-phase work.
model UserProfile {
  id         String     @id @default(uuid())
  authUserId String     @unique // = Supabase auth.users.id
  email      String
  role       Role       @default(operator)
  status     UserStatus @default(active)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // P2-001: back-relations for Merchant FKs (merchants this profile owns / created).
  merchantsOwned   Merchant[] @relation("MerchantOwner")
  merchantsCreated Merchant[] @relation("MerchantCreatedBy")

  // P2-002: back-relations for MerchantProfile audit FKs.
  merchantProfilesCreated MerchantProfile[] @relation("MerchantProfileCreatedBy")
  merchantProfilesUpdated MerchantProfile[] @relation("MerchantProfileUpdatedBy")

  // P2-003: back-relations for MerchantBaselineMetric audit FKs.
  baselineMetricsCreated MerchantBaselineMetric[] @relation("BaselineCreatedBy")
  baselineMetricsUpdated MerchantBaselineMetric[] @relation("BaselineUpdatedBy")

  // P2-004: back-relations for MerchantDiagnosis audit FKs.
  diagnosesCreated MerchantDiagnosis[] @relation("DiagnosisCreatedBy")
  diagnosesUpdated MerchantDiagnosis[] @relation("DiagnosisUpdatedBy")

  // P2-005: back-relations for MerchantAccountSetup audit FKs.
  accountSetupsCreated MerchantAccountSetup[] @relation("AccountSetupCreatedBy")
  accountSetupsUpdated MerchantAccountSetup[] @relation("AccountSetupUpdatedBy")

  // P2-006: back-relations for MerchantMaterialCollection audit FKs.
  materialCollectionsCreated MerchantMaterialCollection[] @relation("MaterialCreatedBy")
  materialCollectionsUpdated MerchantMaterialCollection[] @relation("MaterialUpdatedBy")

  // P2-007: back-relations for MerchantContentOperation audit FKs.
  contentOperationsCreated MerchantContentOperation[] @relation("ContentOperationCreatedBy")
  contentOperationsUpdated MerchantContentOperation[] @relation("ContentOperationUpdatedBy")

  // P2-008: back-relations for MerchantLivePlanning audit FKs.
  livePlanningsCreated MerchantLivePlanning[] @relation("LivePlanningCreatedBy")
  livePlanningsUpdated MerchantLivePlanning[] @relation("LivePlanningUpdatedBy")

  // P2-009: back-relations for MerchantLeadConversion audit FKs.
  leadConversionsCreated MerchantLeadConversion[] @relation("LeadConversionCreatedBy")
  leadConversionsUpdated MerchantLeadConversion[] @relation("LeadConversionUpdatedBy")

  // P2-010: back-relations for MerchantDataReview audit FKs.
  dataReviewsCreated MerchantDataReview[] @relation("DataReviewCreatedBy")
  dataReviewsUpdated MerchantDataReview[] @relation("DataReviewUpdatedBy")

  // P2-011: back-relations for MerchantNinetyDayGrowthPlan audit FKs.
  growthPlansCreated MerchantNinetyDayGrowthPlan[] @relation("GrowthPlanCreatedBy")
  growthPlansUpdated MerchantNinetyDayGrowthPlan[] @relation("GrowthPlanUpdatedBy")

  // P2-016: back-relations for MerchantOperatingCapacity audit FKs.
  operatingCapacitiesCreated MerchantOperatingCapacity[] @relation("OperatingCapacityCreatedBy")
  operatingCapacitiesUpdated MerchantOperatingCapacity[] @relation("OperatingCapacityUpdatedBy")

  // P2-022: back-relations for MerchantStageHandoff (Phase C).
  handoffsSubmitted MerchantStageHandoff[] @relation("HandoffSubmittedBy")
  handoffsReceived  MerchantStageHandoff[] @relation("HandoffReceivedBy")
  handoffsReviewed  MerchantStageHandoff[] @relation("HandoffReviewedBy")
}

// ===== P2-001 Merchant Intake Foundation =====
// First business ROOT entity. MINIMAL intake fields only.
// Deliberately EXCLUDES TB-001 / Merchant Profile Asset fields (客群画像 / 核心卖点 /
// 增长目标 / 投流预算(P-001) / 内容策略 / 诊断评分) — those belong to later TB-001 /
// asset phases (see merchant-asset-catalog-v1 + growth-* architecture docs).
// Diagnostic / strategy / planning / execution / monitoring / review modules will
// hang off this entity in later phases. NOT implemented here.
enum MerchantStatus {
  lead // 已接触 / 待评估
  active // 合作中
  paused // 暂停
  archived // 归档
}

model Merchant {
  id           String         @id @default(uuid())
  name         String
  industry     String?
  city         String?
  country      String?
  contactName  String?
  contactPhone String?
  contactEmail String?
  status       MerchantStatus @default(lead)

  // Ownership / audit. Both reference UserProfile.id (NOT the Supabase auth user id).
  ownerProfileId     String
  owner              UserProfile @relation("MerchantOwner", fields: [ownerProfileId], references: [id])
  createdByProfileId String
  createdBy          UserProfile @relation("MerchantCreatedBy", fields: [createdByProfileId], references: [id])

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // P2-002: optional 1-1 profile asset.
  profile MerchantProfile?

  // P2-003: optional 1-1 baseline metric asset.
  baseline MerchantBaselineMetric?

  // P2-004: optional 1-1 TB-001 minimal diagnosis.
  diagnosis MerchantDiagnosis?

  // P2-005: optional 1-1 TB-002 account setup.
  accountSetup MerchantAccountSetup?

  // P2-006: optional 1-1 TB-003 material collection.
  materialCollection MerchantMaterialCollection?

  // P2-007: optional 1-1 TB-004 content operation.
  contentOperation MerchantContentOperation?

  // P2-008: optional 1-1 TB-005 live planning.
  livePlanning MerchantLivePlanning?

  // P2-009: optional 1-1 TB-006 lead conversion.
  leadConversion MerchantLeadConversion?

  // P2-010: optional 1-1 TB-007 data review.
  dataReview MerchantDataReview?

  // P2-011: optional 1-1 TB-008 90-day growth plan.
  ninetyDayGrowthPlan MerchantNinetyDayGrowthPlan?

  // P2-016: optional 1-1 operating capacity (Fulfillment + Organization intake).
  operatingCapacity MerchantOperatingCapacity?

  // P2-022: many lightweight stage-handoff records (Phase C).
  stageHandoffs MerchantStageHandoff[]

  @@index([ownerProfileId])
  @@index([createdByProfileId])
  @@index([status])
}

// ===== P2-002 Merchant Profile Asset Foundation =====
// First MERCHANT ASSET: a SUMMARY-level profile that feeds later TB-001 / diagnostic /
// strategy / planning. This is NOT the full TB-001 form, NOT diagnostic scoring, NOT AI
// output, NOT P-001 budget detail. 1-1 with Merchant; all summary fields optional.
// Maps to merchant-asset-catalog-v1 "Merchant Profile Asset" (行业 / 客群画像 / 核心卖点 /
// 执行红线 / 增长目标 / 增长前基准) at a summary level only.
model MerchantProfile {
  id         String   @id @default(uuid())
  merchantId String   @unique
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  industryDetail            String?
  targetCustomerSummary     String?
  coreOfferSummary          String?
  currentAcquisitionSummary String?
  onlinePresenceSummary     String?
  growthGoalSummary         String?
  executionLimitSummary     String?
  baselineDataSummary       String?
  notes                     String?

  // Audit — both reference UserProfile.id (NOT the Supabase auth id).
  createdByProfileId String
  createdBy          UserProfile @relation("MerchantProfileCreatedBy", fields: [createdByProfileId], references: [id])
  updatedByProfileId String
  updatedBy          UserProfile @relation("MerchantProfileUpdatedBy", fields: [updatedByProfileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ===== P2-003 Merchant Baseline Metric Foundation =====
// First VERIFIABLE-RESULT INPUT: pre-growth baseline metrics that later TB-001 / MVS /
// ROI / attribution / review / experience compare against. This is NOT a full metric /
// KPI / MVS system, NOT ROI/attribution computation, NOT time-series, NOT charts.
// 1-1 with Merchant; all fields optional. `dataConfidence` is a MINIMAL trust marker
// (NOT the Evidence Framework E1/E2/E3 structure — see evidence-framework-specification-v1).
enum BaselineDataConfidence {
  unknown // 未知 / 未判断
  low // 口头估计
  medium // 有部分记录
  high // 有完整数据来源
}

model MerchantBaselineMetric {
  id         String   @id @default(uuid())
  merchantId String   @unique
  merchant   Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  periodLabel            String?
  monthlyRevenue         Decimal?               @db.Decimal(14, 2)
  monthlyCustomerCount   Int?
  monthlyLeadCount       Int?
  monthlyConversionCount Int?
  averageOrderValue      Decimal?               @db.Decimal(12, 2)
  repeatCustomerRate     Decimal?               @db.Decimal(5, 2)
  followerCount          Int?
  reviewCount            Int?
  averageRating          Decimal?               @db.Decimal(3, 2)
  sourceNote             String?
  dataConfidence         BaselineDataConfidence @default(unknown)
  notes                  String?

  // Audit — both reference UserProfile.id (NOT the Supabase auth id).
  createdByProfileId String
  createdBy          UserProfile @relation("BaselineCreatedBy", fields: [createdByProfileId], references: [id])
  updatedByProfileId String
  updatedBy          UserProfile @relation("BaselineUpdatedBy", fields: [updatedByProfileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

