# TOT — environment variables example.
# Copy to .env.local (gitignored) and fill REAL values. NEVER commit real secrets.
#
# === Database: Supabase Postgres (accessed via Prisma) ===
# App runtime — Supabase POOLED connection (Transaction pooler, port 6543).
# Must include ?pgbouncer=true&connection_limit=1 for serverless/Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"

# Prisma migrations — Supabase DIRECT connection (port 5432).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# === Supabase Auth (P1) ===
# Project URL + anon key — REQUIRED for login/logout/route guard to work at runtime.
# anon key is public/safe to expose to the browser (it is a NEXT_PUBLIC_ var).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-SUPABASE-ANON-KEY"

# Service role key — SERVER-ONLY, NEVER expose to the browser / never prefix NEXT_PUBLIC.
# Reserved for later server-side admin ops (e.g. role management). NOT used by P1 code yet.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SUPABASE-SERVICE-ROLE-KEY"

# --- Reserved for later phases (do not set yet) ---
# ANTHROPIC_API_KEY=               # P3 AI draft generation
